# ============================================
# LLM Configuration
# ============================================
# Provider: "ollama" (local, free) or "groq" (cloud API, free tier)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Groq settings (used when LLM_PROVIDER=groq, for cloud deployment)
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Embedding Model (always local, always free)
# ============================================
# multilingual-e5-base supports Italian + English (278MB, 768 dim)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Device for embedding inference: "cpu", "cuda" (NVIDIA), "mps" (Apple Silicon)
# Default "cpu" works everywhere — override locally if you have a supported GPU
EMBEDDING_DEVICE=cpu

# ============================================
# Vector Database
# ============================================
CHROMA_PATH=./chroma_db
COLLECTION_NAME=documents

# ============================================
# RAG Parameters
# ============================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=4

# ============================================
# Observability (optional, free tier)
# ============================================
# Sign up at https://cloud.langfuse.com (free tier)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
